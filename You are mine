<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tahreem Birthday Gate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
      --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --text-lg: clamp(1.125rem, 1rem + 0.75vw, 1.5rem);
      --text-xl: clamp(1.5rem, 1.2rem + 1.25vw, 2.25rem);
      --text-2xl: clamp(2rem, 1.2rem + 2.5vw, 3.5rem);
      --text-3xl: clamp(2.5rem, 1rem + 4vw, 5rem);
      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-5: 1.25rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-10: 2.5rem;
      --space-12: 3rem;
      --space-16: 4rem;
      --radius-md: 0.75rem;
      --radius-lg: 1.25rem;
      --radius-xl: 1.75rem;
      --radius-full: 9999px;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'Manrope', Arial, sans-serif;
      --color-bg: #fff3f8;
      --color-surface: rgba(255,255,255,0.52);
      --color-surface-2: rgba(255,255,255,0.7);
      --color-text: #5e1730;
      --color-text-muted: #91506b;
      --color-primary: #ff4d8d;
      --color-primary-2: #ff7a59;
      --color-primary-3: #ffd166;
      --color-border: rgba(255,255,255,0.55);
      --shadow-lg: 0 20px 60px rgba(255, 91, 145, 0.22);
      --shadow-md: 0 10px 30px rgba(255, 91, 145, 0.16);
    }

    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: var(--font-body);
      color: var(--color-text);
      background:
        radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.9), transparent 18%),
        radial-gradient(circle at 80% 15%, rgba(255, 209, 102, 0.45), transparent 22%),
        radial-gradient(circle at 75% 70%, rgba(255, 122, 89, 0.38), transparent 24%),
        radial-gradient(circle at 25% 80%, rgba(255, 77, 141, 0.35), transparent 24%),
        linear-gradient(135deg, #ffd8e8 0%, #ffc4db 18%, #ffb6c9 38%, #ffb38a 67%, #ffe08a 100%);
      overflow: hidden;
    }

    .floating-hearts {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .heart {
      position: absolute;
      bottom: -40px;
      color: rgba(255,255,255,0.72);
      font-size: clamp(1rem, 0.8rem + 1vw, 2rem);
      animation: floatUp linear infinite;
      filter: drop-shadow(0 8px 12px rgba(255, 105, 155, 0.16));
    }

    .page {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: var(--space-6);
      position: relative;
      isolation: isolate;
    }

    .glow {
      position: absolute;
      width: 20rem;
      height: 20rem;
      border-radius: 50%;
      filter: blur(40px);
      opacity: 0.45;
      z-index: -1;
    }

    .glow.one { top: 8%; left: 8%; background: rgba(255, 255, 255, 0.55); }
    .glow.two { bottom: 7%; right: 8%; background: rgba(255, 77, 141, 0.28); }

    .card {
      width: min(100%, 760px);
      padding: clamp(1.5rem, 2vw, 2.2rem);
      background: linear-gradient(180deg, rgba(255,255,255,0.58), rgba(255,255,255,0.34));
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.65rem 1rem;
      border-radius: var(--radius-full);
      background: rgba(255,255,255,0.72);
      color: #b03a68;
      font-size: var(--text-sm);
      font-weight: 700;
      letter-spacing: 0.04em;
      box-shadow: var(--shadow-md);
    }

    h1 {
      margin: 1.2rem 0 0.8rem;
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      line-height: 1.02;
      max-width: 12ch;
    }

    p {
      margin: 0;
      font-size: var(--text-base);
      color: var(--color-text-muted);
      max-width: 52ch;
      line-height: 1.75;
    }

    .name-box {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .input-wrap {
      padding: 0.4rem;
      border-radius: calc(var(--radius-lg) + 0.2rem);
      background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,255,255,0.55));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), var(--shadow-md);
    }

    input {
      width: 100%;
      border: 0;
      outline: none;
      background: rgba(255,255,255,0.78);
      color: var(--color-text);
      padding: 1.1rem 1.15rem;
      border-radius: var(--radius-lg);
      font-size: var(--text-base);
      min-height: 56px;
    }

    input::placeholder { color: #b57a94; }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
    }

    .btn {
      min-height: 52px;
      padding: 0.95rem 1.4rem;
      border: 0;
      border-radius: var(--radius-full);
      font-size: var(--text-sm);
      font-weight: 800;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-2));
      box-shadow: 0 14px 26px rgba(255, 77, 141, 0.34);
    }

    .btn-secondary {
      color: #b03a68;
      background: rgba(255,255,255,0.7);
      box-shadow: var(--shadow-md);
    }

    .btn:hover { transform: translateY(-2px) scale(1.01); }

    .little-note {
      margin-top: 1rem;
      font-size: var(--text-sm);
      color: #aa6580;
    }

    .popup {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1.25rem;
      background: rgba(124, 28, 61, 0.28);
      backdrop-filter: blur(8px);
      z-index: 50;
    }

    .popup.active { display: flex; }

    .popup-card {
      width: min(100%, 380px);
      background: linear-gradient(180deg, #fff7fa, #ffe4ed);
      color: #7b2246;
      border-radius: 1.4rem;
      padding: 1.4rem;
      box-shadow: 0 24px 80px rgba(87, 25, 47, 0.24);
      text-align: center;
      border: 1px solid rgba(255,255,255,0.75);
    }

    .popup-card h2 {
      margin: 0.3rem 0 0.5rem;
      font-size: var(--text-xl);
      font-family: var(--font-display);
    }

    .popup-card p {
      color: #8d4f68;
      margin: 0 auto 1rem;
      max-width: 24ch;
    }

    .heart-icon {
      width: 74px;
      aspect-ratio: 1;
      margin: 0 auto 0.6rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #fff, #ffd3e2 55%, #ff98b9 100%);
      box-shadow: inset 0 2px 8px rgba(255,255,255,0.7);
      font-size: 1.8rem;
    }

    .success-note {
      margin-top: 1.2rem;
      display: none;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 1.1rem;
      border-radius: 1rem;
      background: rgba(255,255,255,0.6);
      color: #8b3059;
      box-shadow: var(--shadow-md);
    }

    .success-note.show { display: flex; }

    @keyframes floatUp {
      from { transform: translateY(0) scale(0.9); opacity: 0; }
      15% { opacity: 0.95; }
      to { transform: translateY(-115vh) scale(1.1); opacity: 0; }
    }

    @media (max-width: 640px) {
      h1 { max-width: 10ch; }
      .card { padding: 1.25rem; }
      .actions { flex-direction: column; }
      .btn { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="floating-hearts" aria-hidden="true">
    <span class="heart" style="left: 8%; animation-duration: 14s; animation-delay: 0s;">❤</span>
    <span class="heart" style="left: 18%; animation-duration: 11s; animation-delay: 2s;">♥</span>
    <span class="heart" style="left: 31%; animation-duration: 15s; animation-delay: 5s;">❤</span>
    <span class="heart" style="left: 47%; animation-duration: 12s; animation-delay: 1s;">♥</span>
    <span class="heart" style="left: 58%; animation-duration: 16s; animation-delay: 3s;">❤</span>
    <span class="heart" style="left: 71%; animation-duration: 13s; animation-delay: 6s;">♥</span>
    <span class="heart" style="left: 84%; animation-duration: 17s; animation-delay: 4s;">❤</span>
  </div>

  <main class="page">
    <div class="glow one"></div>
    <div class="glow two"></div>

    <section class="card">
      <span class="badge">💖 Birthday surprise gate</span>
      <h1>If you are my girl, enter your beautiful name</h1>
      <p>
        This little page is only for one special person. Type the right name,
        and the surprise opens like magic.
      </p>

      <form class="name-box" id="loveForm">
        <div class="input-wrap">
          <label class="sr-only" for="girlName"></label>
          <input id="girlName" name="girlName" type="text" placeholder="Enter your name here..." autocomplete="off" />
        </div>

        <div class="actions">
          <button class="btn btn-primary" type="submit">Open the surprise ✨</button>
        </div>
      </form>

      <p class="little-note">Hint: only the name <strong>Tahreem</strong> can enter.</p>

      <div class="success-note" id="successNote" aria-live="polite">
        <span>💌</span>
        <span>Name matched. This is where page 2 will open next.</span>
      </div>
    </section>
  </main>

  <div class="popup" id="wrongPopup" role="dialog" aria-modal="true" aria-labelledby="popupTitle">
    <div class="popup-card">
      <div class="heart-icon">💗</div>
      <h2 id="popupTitle">You are not my girl</h2>
      <p>Sorry cutie, this birthday surprise is locked for someone special only.</p>
      <button class="btn btn-primary" type="button" id="closePopup">Okay</button>
    </div>
  </div>

  <script>
    const form = document.getElementById('loveForm');
    const input = document.getElementById('girlName');
    const popup = document.getElementById('wrongPopup');
    const closePopup = document.getElementById('closePopup');
    const fillName = document.getElementById('fillName');
    const successNote = document.getElementById('successNote');

    function normalize(value) {
      return value.trim().toLowerCase();
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const entered = normalize(input.value);

      if (entered === 'tahreem') {
        successNote.classList.add('show');
        popup.classList.remove('active');
        setTimeout(() => {
          alert('Correct name! Next I can build page 2 for Tahreem birthday reveal.');
        }, 150);
      } else {
        successNote.classList.remove('show');
        popup.classList.add('active');
      }
    });

    fillName.addEventListener('click', function () {
      input.value = 'Tahreem';
      input.focus();
    });

    closePopup.addEventListener('click', function () {
      popup.classList.remove('active');
      input.focus();
    });

    popup.addEventListener('click', function (e) {
      if (e.target === popup) popup.classList.remove('active');
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') popup.classList.remove('active');
    });
  </script>
</body>
</html>
